name: Depot CI - OpenClaw Performance Test

on:
  workflow_dispatch:
    inputs:
      test_case:
        description: 'Performance test case'
        required: true
        default: 'baseline'
        type: choice
        options:
          - baseline
          - test-2-docs
          - test-3-source
          - test-4-ui
          - test-5-dependency
          - test-6-major

permissions:
  contents: read
  id-token: write

env:
  DEPOT_PROJECT_ID: ${{ secrets.DEPOT_PROJECT_ID }}

jobs:
  depot-ci-build:
    name: Depot CI Build - OpenClaw
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: Checkout OpenClaw
        uses: actions/checkout@v4
        with:
          repository: openclaw/openclaw
          ref: main

      - name: Checkout test scripts
        uses: actions/checkout@v4
        with:
          path: _test-scripts

      - name: Install Depot CLI
        run: |
          curl -fsSL https://depot.dev/install-cli.sh | sh
          echo "$HOME/.depot/bin" >> $GITHUB_PATH

      - name: Apply test case
        run: _test-scripts/scripts/apply-openclaw-test-case.sh "${{ github.event.inputs.test_case }}"

      - name: Display test info
        run: |
          echo "=========================================="
          echo "Depot CI Performance Test - OpenClaw"
          echo "=========================================="
          echo "Test Case: ${{ github.event.inputs.test_case }}"
          echo "Description: ${{ env.test_description }}"
          echo "Expected Cache Hit: ${{ env.expected_cache }}"
          echo "=========================================="

      - name: Build with Depot CI
        run: |
          echo "Starting Depot CI build..."
          echo "Test: ${{ github.event.inputs.test_case }}"
          depot build -t openclaw:test-${{ github.event.inputs.test_case }} .
        env:
          DEPOT_TOKEN: ${{ secrets.DEPOT_TOKEN }}

      - name: Display build results
        run: |
          echo "=========================================="
          echo "Build Complete!"
          echo "=========================================="
          echo "Image: openclaw:test-${{ github.event.inputs.test_case }}"
          echo "Test Case: ${{ github.event.inputs.test_case }}"
          echo "Description: ${{ env.test_description }}"
          echo "Expected Cache: ${{ env.expected_cache }}"
          echo "=========================================="
